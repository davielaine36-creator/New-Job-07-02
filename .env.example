# ─────────────────────────────────────────────────────────────
# Copy to .env.local for local dev, and set in Vercel for prod.
# With NONE of these set, the site runs on bundled local markdown
# and forms work in "preview" mode (captured to logs). Wire the
# variables below to go live.
# ─────────────────────────────────────────────────────────────

# Public canonical URL (used for SEO, OG, sitemap, RSS)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Content: Headless Ghost (recommended) ────────────────────
# When both are set, the site reads content from Ghost instead of
# the bundled markdown. Author publishes/edits in Ghost admin.
GHOST_URL=https://your-site.ghost.io
GHOST_CONTENT_API_KEY=

# ── Newsletter subscription ──────────────────────────────────
# Option A — Ghost Members (one backend for content + email):
#   Point at your Ghost site's Members magic-link/signup endpoint.
GHOST_MEMBERS_INTEGRATION_URL=

# Option B — Dedicated ESP (Beehiiv / Kit) if best-of-breed:
ESP_SUBSCRIBE_URL=
ESP_API_KEY=

# ── On-demand revalidation (Ghost → Next webhook) ────────────
# Set a strong secret; configure a Ghost webhook to
#   POST /api/revalidate?secret=THIS_VALUE
REVALIDATE_SECRET=

# ── "Work With Me" enquiry delivery ──────────────────────────
# A private webhook (Slack / Discord / n8n / Zapier / email trigger).
ENQUIRY_WEBHOOK_URL=
