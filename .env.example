# ─────────────────────────────────────────────────────────────
# Copy to .env.local for local dev, and set in Vercel for prod.
#
# AI WORK RADAR runs with ZERO of these set: mock database, mock AI,
# mock lead source, simulated email. Turn on real adapters one at a
# time by filling in the relevant block and flipping RADAR_MODE=live.
# ─────────────────────────────────────────────────────────────

# Public base URL (used to build demo preview + unsubscribe links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Master switches ──────────────────────────────────────────
# mock  → fully simulated, safe to run anywhere (default)
# live  → use whichever real adapters are configured below
RADAR_MODE=mock
# true → the loop runs end-to-end on the cron without approval (default true)
AUTONOMOUS_MODE=true
# Shared secret for the cron + agent trigger endpoints (recommended in prod).
# Vercel Cron requests are allowed automatically.
RADAR_CRON_SECRET=

# ── Database: Supabase (optional) ────────────────────────────
# With both set, storage switches from the in-memory/file mock to Supabase.
# Apply supabase/migrations/0001_init.sql first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Guard: allow the destructive reset endpoint against a live DB (default off)
RADAR_ALLOW_RESET=false

# ── AI model: Anthropic (optional) ───────────────────────────
# Without a key the deterministic mock model is used for every agent.
ANTHROPIC_API_KEY=
RADAR_AI_MODEL=claude-opus-4-8
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Lead source: Google Places (optional) ────────────────────
# Official Places API only — never scrapes Google Maps HTML.
GOOGLE_PLACES_API_KEY=

# ── Email sending: Resend (optional) ─────────────────────────
# Without these, sends are simulated. Authenticate your domain (SPF/DKIM/DMARC)
# in Resend before going live.
RADAR_EMAIL_PROVIDER=       # "resend" to enable real sending
RESEND_API_KEY=
RADAR_FROM_EMAIL=           # e.g. "Alex Rivera <alex@yourdomain.com>"

# ── Legacy: Circle Health marketing demo (unrelated to Radar) ─
# The /(site) marketing pages still work; these stay optional.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
GHOST_URL=
GHOST_CONTENT_API_KEY=
REVALIDATE_SECRET=
DEMO_WEBHOOK_URL=
