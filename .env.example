# ─────────────────────────────────────────────────────────────
# Copy to .env.local for local dev, and set in Vercel for prod.
# With NONE of these set, the site runs on bundled local markdown
# (Insights) and the demo form works in "preview" mode (captured to
# logs). Wire the variables below to go live.
# ─────────────────────────────────────────────────────────────

# Public canonical URL (used for SEO, OG, sitemap, RSS)
NEXT_PUBLIC_SITE_URL=https://www.circlehealth.co

# ── Insights content: Headless Ghost (optional) ──────────────
# When both are set, Insights are read from Ghost (posts tagged
# `insight`) instead of the bundled markdown. A non-technical author
# publishes and edits in Ghost admin.
GHOST_URL=https://your-site.ghost.io
GHOST_CONTENT_API_KEY=

# ── On-demand revalidation (Ghost → Next webhook) ────────────
# Set a strong secret; configure a Ghost webhook to
#   POST /api/revalidate?secret=THIS_VALUE
REVALIDATE_SECRET=

# ── Demo request delivery ────────────────────────────────────
# A private webhook (CRM / Slack / n8n / Zapier / email trigger)
# that receives demo requests submitted through /demo. If unset,
# requests are logged in preview mode so the form is demonstrable.
DEMO_WEBHOOK_URL=
